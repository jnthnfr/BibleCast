{
  "name": "biblecast",
  "version": "1.4.2",
  "description": "Scripture broadcasting software for presenting and projecting Bible verses in church",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/launch.js",
    "dev": "cross-env NODE_ENV=development node scripts/launch.js",
    "seed": "node scripts/seed-db.js",
    "download": "node scripts/download-translations.js",
    "download:kjv": "node scripts/download-translations.js kjv",
    "bundle:kjv": "node scripts/bundle-kjv.js",
    "bundle:all": "node scripts/bundle-kjv.js kjv asv web ylt bbe dby wbs hnv",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": [
    "bible",
    "church",
    "projection",
    "scripture",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/jnthnfr/BibleCast"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.3",
    "vosk-browser": "^0.0.8"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  }
}
