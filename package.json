{
  "name": "biblecast",
  "version": "1.0.0",
  "description": "Scripture broadcasting software for presenting and projecting Bible verses in church",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "seed": "node scripts/seed-db.js",
    "download": "node scripts/download-translations.js",
    "download:kjv": "node scripts/download-translations.js kjv",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": [
    "bible",
    "church",
    "projection",
    "scripture",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  }
}
